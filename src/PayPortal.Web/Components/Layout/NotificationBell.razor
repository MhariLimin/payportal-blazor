@rendermode InteractiveServer
@inject IActivityService ActivityService

<AuthorizeView Roles="@PortalRoles.Merchant">
    <Authorized>
        <div class="notification-wrap">
            <button class="notification-button" type="button" aria-label="Open notifications" @onclick="OpenAsync">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 22a2.5 2.5 0 0 0 2.4-1.8H9.6A2.5 2.5 0 0 0 12 22Zm7-6.5-1.7-2V9a5.3 5.3 0 0 0-4.1-5.2V3a1.2 1.2 0 0 0-2.4 0v.8A5.3 5.3 0 0 0 6.7 9v4.5l-1.7 2A1.5 1.5 0 0 0 6.2 18h11.6a1.5 1.5 0 0 0 1.2-2.5Z" />
                </svg>
                @if (ActionRequiredCount > 0)
                {
                    <strong>@ActionRequiredCount</strong>
                }
            </button>
        </div>

        @if (showModal)
        {
            <div class="modal-backdrop notification-backdrop" @onclick="Close">
                <section class="modal notification-modal" @onclick:stopPropagation="true">
                    <div class="card-title">
                        <div>
                            <h2>Notifications</h2>
                            <span class="muted">@ActionRequiredCount action needed</span>
                        </div>
                        <button class="icon-button" @onclick="Close">Close</button>
                    </div>
                    <div class="modal-body">
                        <h3>Action Required</h3>
                        <div class="list compact-list bordered">
                            @foreach (var item in items.Where(IsActionRequired).Take(8))
                            {
                                <a class="list-row" href="@ActivityUrl(item)">
                                    <span class="timeline-dot"></span>
                                    <span class="list-row-main">
                                        <h3>@item.Title</h3>
                                        <p>@item.Description</p>
                                        <small class="muted">@item.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</small>
                                    </span>
                                </a>
                            }
                            @if (!items.Any(IsActionRequired))
                            {
                                <div class="empty-state muted">No immediate action is required.</div>
                            }
                        </div>
                    </div>
                </section>
            </div>
        }
    </Authorized>
</AuthorizeView>

@code {
    private IReadOnlyList<ActivityLogItem> items = [];
    private bool showModal;

    private int ActionRequiredCount => items.Count(IsActionRequired);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task OpenAsync()
    {
        await LoadAsync();
        showModal = true;
    }

    private void Close() => showModal = false;

    private async Task LoadAsync() =>
        items = await ActivityService.ListAsync(new ActivityLogFilter(null, null, null, null, null), 30);

    private static bool IsActionRequired(ActivityLogItem item) =>
        item.Action is "application_moreinformationrequired" or "kyc_document_rejected";

    private static string ActivityUrl(ActivityLogItem item) =>
        item.Action.Contains("document", StringComparison.OrdinalIgnoreCase) ? "/kyc" : "/merchant/profile";
}
