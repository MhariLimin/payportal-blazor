@rendermode InteractiveServer
@inject IActivityService ActivityService

<AuthorizeView Roles="@PortalRoles.Merchant">
    <Authorized>
        <div class="notification-wrap">
            <button class="notification-button" type="button" aria-label="Open notifications" @onclick="OpenAsync">
                <span>N</span>
                @if (ActionRequiredCount > 0)
                {
                    <strong>@ActionRequiredCount</strong>
                }
            </button>
        </div>

        @if (showModal)
        {
            <div class="modal-backdrop">
                <section class="modal notification-modal">
                    <div class="card-title">
                        <div>
                            <h2>Notifications</h2>
                            <span class="muted">@items.Count merchant updates</span>
                        </div>
                        <button class="icon-button" @onclick="() => showModal = false">Close</button>
                    </div>
                    <div class="modal-body grid two">
                        <article>
                            <h3>Action Required</h3>
                            <div class="list compact-list bordered">
                                @foreach (var item in items.Where(IsActionRequired).Take(6))
                                {
                                    <a class="list-row" href="@ActivityUrl(item)">
                                        <span class="timeline-dot"></span>
                                        <span class="list-row-main"><h3>@item.Title</h3><p>@item.Description</p></span>
                                    </a>
                                }
                                @if (!items.Any(IsActionRequired))
                                {
                                    <div class="empty-state muted">No immediate action is required.</div>
                                }
                            </div>
                        </article>
                        <article>
                            <h3>Recent Updates</h3>
                            <div class="list compact-list bordered">
                                @foreach (var item in items.Take(8))
                                {
                                    <a class="list-row" href="@ActivityUrl(item)">
                                        <span class="timeline-dot complete"></span>
                                        <span class="list-row-main">
                                            <h3>@item.Title</h3>
                                            <p>@item.Description</p>
                                            <small class="muted">@item.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</small>
                                        </span>
                                    </a>
                                }
                            </div>
                        </article>
                    </div>
                    <div class="modal-actions">
                        <a class="button secondary" href="/merchant-activity">Open Activity</a>
                        <button class="button primary" @onclick="() => showModal = false">Done</button>
                    </div>
                </section>
            </div>
        }
    </Authorized>
</AuthorizeView>

@code {
    private IReadOnlyList<ActivityLogItem> items = [];
    private bool showModal;

    private int ActionRequiredCount => items.Count(IsActionRequired);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task OpenAsync()
    {
        await LoadAsync();
        showModal = true;
    }

    private async Task LoadAsync() =>
        items = await ActivityService.ListAsync(new ActivityLogFilter(null, null, null, null, null), 30);

    private static bool IsActionRequired(ActivityLogItem item) =>
        item.Action is "application_moreinformationrequired" or "kyc_document_rejected";

    private static string ActivityUrl(ActivityLogItem item) =>
        item.Action.Contains("document", StringComparison.OrdinalIgnoreCase) ? "/document-requests" : "/merchant/profile";
}
