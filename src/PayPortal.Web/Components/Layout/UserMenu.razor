@rendermode InteractiveServer
@inject IJSRuntime JS

<AuthorizeView>
    <Authorized Context="auth">
        <div class="user-menu-wrap">
            <button class="user-summary" type="button" aria-haspopup="menu"
                    aria-expanded="@showUserMenu" @onclick="ToggleUserMenu">
                @if (auth.User.IsInRole(PortalRoles.Merchant))
                {
                    <span class="avatar-stack">
                        <span class="avatar">@auth.User.Identity?.Name?.FirstOrDefault()</span>
                        <img class="avatar image" src="/merchant-logos/current" alt=""
                             onerror="this.style.display='none'" />
                    </span>
                }
                else
                {
                    <span class="avatar">@auth.User.Identity?.Name?.FirstOrDefault()</span>
                }
                <span class="user-name">
                    <strong>@DisplayName(auth.User.Identity?.Name)</strong>
                    <small>@RoleLabel(auth.User)</small>
                </span>
                <span class="menu-chevron">@(showUserMenu ? "^" : "v")</span>
            </button>
            @if (showUserMenu)
            {
                <div class="user-dropdown" role="menu">
                    <div class="dropdown-heading">
                        <strong>@auth.User.Identity?.Name</strong>
                        <span>@RoleLabel(auth.User)</span>
                    </div>
                    @if (auth.User.IsInRole(PortalRoles.Merchant))
                    {
                        <a class="dropdown-link" role="menuitem" href="/merchant/profile">Profile</a>
                    }
                    <button type="button" role="menuitem" @onclick='() => SetThemeAsync("light")'>Light mode</button>
                    <button type="button" role="menuitem" @onclick='() => SetThemeAsync("dark")'>Dark mode</button>
                    <button type="button" role="menuitem" @onclick='() => SetThemeAsync("system")'>Use system theme</button>
                    <form action="/account/logout" method="post">
                        <AntiforgeryToken />
                        <button class="logout-action" type="submit">Log out</button>
                    </form>
                </div>
            }
        </div>
    </Authorized>
</AuthorizeView>

@code {
    private bool showUserMenu;

    private void ToggleUserMenu() => showUserMenu = !showUserMenu;

    private async Task SetThemeAsync(string theme)
    {
        await JS.InvokeVoidAsync("payPortalTheme.set", theme);
        showUserMenu = false;
    }

    private static string DisplayName(string? email) =>
        string.IsNullOrWhiteSpace(email) ? "Account" : email.Split('@')[0];

    private static string RoleLabel(System.Security.Claims.ClaimsPrincipal user) =>
        user.IsInRole(PortalRoles.Admin) ? "Administrator" : "Merchant";
}
