@inherits LayoutComponentBase
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IMerchantService MerchantService
@inject IJSRuntime JS

<div class="app-shell">
    <header class="topbar">
        <a class="brand" href="/">
            <span class="brand-mark brand-art" aria-hidden="true"></span>
            <span>PayPortal</span>
        </a>
        <div class="workspace-context">
            <span class="context-label">Merchant operations</span>
            <span class="context-status">Secure workspace</span>
        </div>
        <AuthorizeView>
            <Authorized Context="auth">
                <div class="user-menu-wrap">
                    <button class="user-summary" type="button" aria-expanded="@showUserMenu" @onclick="ToggleUserMenu">
                        @if (merchant?.LogoStorageName is not null)
                        {
                            <img class="avatar image" src="/merchant-logos/@merchant.Id" alt="" />
                        }
                        else
                        {
                            <span class="avatar">@auth.User.Identity?.Name?.FirstOrDefault()</span>
                        }
                        <span class="user-name">
                            <strong>@DisplayName(auth.User.Identity?.Name)</strong>
                            <small>@RoleLabel(auth.User)</small>
                        </span>
                        <span class="menu-chevron">v</span>
                    </button>
                    @if (showUserMenu)
                    {
                        <div class="user-dropdown">
                            <div class="dropdown-heading">
                                <strong>@auth.User.Identity?.Name</strong>
                                <span>@RoleLabel(auth.User)</span>
                            </div>
                            <button type="button" @onclick='() => SetThemeAsync("light")'>Light mode</button>
                            <button type="button" @onclick='() => SetThemeAsync("dark")'>Dark mode</button>
                            <button type="button" @onclick='() => SetThemeAsync("system")'>Use system theme</button>
                            <form action="/account/logout" method="post">
                                <AntiforgeryToken />
                                <button class="logout-action" type="submit">Log out</button>
                            </form>
                        </div>
                    }
                </div>
            </Authorized>
        </AuthorizeView>
    </header>
    <aside class="sidebar">
        <div class="sidebar-label">Workspace</div>
        <NavMenu />
        <div class="sidebar-card">
            <strong>Need a status check?</strong>
            <span>Open the dashboard for onboarding progress and recent activity.</span>
        </div>
    </aside>
    <main class="content">
        @Body
    </main>
</div>

@code {
    private Merchant? merchant;
    private bool showUserMenu;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (state.User.IsInRole(PortalRoles.Merchant))
        {
            merchant = await MerchantService.GetAccessibleAsync(null);
        }
    }

    private void ToggleUserMenu() => showUserMenu = !showUserMenu;

    private async Task SetThemeAsync(string theme)
    {
        await JS.InvokeVoidAsync("payPortalTheme.set", theme);
        showUserMenu = false;
    }

    private static string DisplayName(string? email) =>
        string.IsNullOrWhiteSpace(email) ? "Account" : email.Split('@')[0];

    private static string RoleLabel(System.Security.Claims.ClaimsPrincipal user) =>
        user.IsInRole(PortalRoles.Admin) ? "Administrator" : "Merchant";
}
