@inherits LayoutComponentBase

<div class="app-shell">
    <header class="topbar">
        <a class="brand" href="/">
            <span class="brand-mark brand-art" aria-hidden="true"></span>
            <span>PayPortal</span>
        </a>
        <div class="workspace-context">
            <span class="context-label">Merchant operations</span>
            <span class="context-status">Secure workspace</span>
        </div>
        <div class="account-actions">
            <AuthorizeView Roles="@PortalRoles.Merchant">
                <Authorized>
                    <NotificationBell />
                </Authorized>
            </AuthorizeView>
            <UserMenu />
        </div>
    </header>
    <aside class="sidebar">
        <div class="sidebar-label">Workspace</div>
        <NavMenu />
        <div class="sidebar-card">
            <strong>Next best action</strong>
            <AuthorizeView Roles="@PortalRoles.Admin">
                <Authorized>
                    <span>Start with Applications for decisions, then use Activity to audit changes.</span>
                    <a href="/applications">Open Applications</a>
                    <a href="/activity">Review Activity</a>
                </Authorized>
            </AuthorizeView>
            <AuthorizeView Roles="@PortalRoles.Merchant">
                <Authorized>
                    <span>Complete your KYC checklist first. API access unlocks after approval.</span>
                    <a href="/kyc">Open KYC Checklist</a>
                    <a href="/merchant/profile">Update Profile</a>
                </Authorized>
            </AuthorizeView>
        </div>
    </aside>
    <main class="content">
        @Body
    </main>
</div>
