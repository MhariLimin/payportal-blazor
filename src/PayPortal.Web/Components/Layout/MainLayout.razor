@inherits LayoutComponentBase

<div class="app-shell">
    <header class="topbar">
        <a class="brand" href="/">
            <span class="brand-mark">P</span>
            <span>PayPortal</span>
        </a>
        <div class="topbar-search">Search merchants, applications...</div>
        <AuthorizeView>
            <Authorized Context="auth">
                <div class="user-summary">
                    <span class="avatar">@auth.User.Identity?.Name?.FirstOrDefault()</span>
                    <span class="user-name">@auth.User.Identity?.Name</span>
                    <form action="/account/logout" method="post">
                        <AntiforgeryToken />
                        <button class="icon-button" type="submit" title="Logout">Log out</button>
                    </form>
                </div>
            </Authorized>
        </AuthorizeView>
    </header>
    <aside class="sidebar">
        <NavMenu />
        <div class="support-card">
            <strong>Need help?</strong>
            <span>See the project documentation.</span>
            <a href="/docs">View documentation</a>
        </div>
    </aside>
    <main class="content">
        @Body
    </main>
</div>
