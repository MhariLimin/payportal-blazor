@rendermode InteractiveServer
@inject NavigationManager Navigation

<nav class="nav-menu">
    <NavLink href="/" Match="NavLinkMatch.All"><span class="nav-icon">D</span> Dashboard</NavLink>
    <AuthorizeView Roles="@PortalRoles.Admin">
        <div class="nav-group @(adminOnboardingOpen ? "open" : "")">
            <button type="button" @onclick="() => adminOnboardingOpen = !adminOnboardingOpen"><span class="nav-icon">O</span> Onboarding</button>
            @if (adminOnboardingOpen)
            {
            <NavLink href="/applications"><span class="nav-icon">A</span> Applications</NavLink>
            <NavLink href="/document-requests"><span class="nav-icon">Q</span> Document Requests</NavLink>
            }
        </div>
        <NavLink href="/merchant-directory"><span class="nav-icon">M</span> Merchant Directory</NavLink>
        <NavLink href="/activity"><span class="nav-icon">L</span> Activity</NavLink>
        <div class="nav-group @(adminMonitoringOpen ? "open" : "")">
            <button type="button" @onclick="() => adminMonitoringOpen = !adminMonitoringOpen"><span class="nav-icon">M</span> Monitoring</button>
            @if (adminMonitoringOpen)
            {
            <NavLink href="/risk-rules"><span class="nav-icon">R</span> Risk Rules</NavLink>
            <NavLink href="/api-usage"><span class="nav-icon">U</span> API Usage</NavLink>
            <NavLink href="/reports"><span class="nav-icon">R</span> Reports</NavLink>
            }
        </div>
    </AuthorizeView>
    <AuthorizeView Roles="@PortalRoles.Merchant">
        <NavLink href="/kyc"><span class="nav-icon">K</span> KYC Verification</NavLink>
        <NavLink href="/merchant-activity"><span class="nav-icon">A</span> Activity</NavLink>
        <div class="nav-group @(merchantApiOpen ? "open" : "")">
            <button type="button" @onclick="() => merchantApiOpen = !merchantApiOpen"><span class="nav-icon">A</span> API</button>
            @if (merchantApiOpen)
            {
            <NavLink href="/api-credentials"><span class="nav-icon">C</span> API Credentials</NavLink>
            <NavLink href="/api-usage"><span class="nav-icon">U</span> API Usage</NavLink>
            }
        </div>
    </AuthorizeView>
</nav>

@code {
    private bool adminOnboardingOpen = true;
    private bool adminMonitoringOpen;
    private bool merchantApiOpen;

    protected override void OnInitialized()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri).TrimEnd('/');
        adminOnboardingOpen = path is "applications" or "admin/reviews" or "document-requests";
        adminMonitoringOpen = path is "risk-rules" or "api-usage" or "reports";
        merchantApiOpen = path is "api-credentials" or "api-usage";
    }
}
