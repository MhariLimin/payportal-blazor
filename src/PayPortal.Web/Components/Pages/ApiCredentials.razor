@page "/api-credentials"
@rendermode InteractiveServer
@attribute [Authorize(Roles = PortalRoles.Merchant)]
@inject IMerchantService MerchantService
@inject ICredentialService CredentialService

<PageTitle>API credentials - PayPortal</PageTitle>

@if (merchant is null)
{
    <section class="card">Loading API credentials...</section>
}
else
{
    <div class="page">
        <header class="page-header">
            <div><h1>API Credentials</h1><p>@merchant.CompanyName · API keys and webhook configuration</p></div>
            <button class="button primary" disabled="@(merchant.Status != MerchantStatus.Approved)" @onclick="() => showCreate = true">Create Key</button>
        </header>

        @if (merchant.Status != MerchantStatus.Approved)
        {
            <div class="alert error">Production and sandbox credentials become available after application approval.</div>
        }

        @if (issued is not null)
        {
            <section class="secret">
                <h2>Save this secret now</h2>
                <p>This is the only time PayPortal displays the secret.</p>
                <p><strong>API key</strong></p><div class="code">@issued.PublicKey</div>
                <p><strong>Secret</strong></p><div class="code">@issued.Secret</div>
                <button class="button secondary" @onclick="() => issued = null">I have saved it</button>
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert error">@error</div>
        }

        <section class="card flush">
            <div class="card-title"><h2>API Keys</h2><span class="muted">@merchant.ApiCredentials.Count keys</span></div>
            <div class="list">
                @if (merchant.ApiCredentials.Count == 0)
                {
                    <div class="empty-state"><h3>No API keys</h3><p class="muted">Create your first key after approval.</p></div>
                }
                @foreach (var credential in merchant.ApiCredentials.OrderByDescending(x => x.CreatedAtUtc))
                {
                    <div class="credential-row">
                        <div class="credential-main">
                            <div class="credential-heading">
                                <span class="company-icon">⚿</span>
                                <div><h3>@credential.Name</h3><p>@credential.Environment · Created @credential.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy")</p></div>
                                <span class="badge @(credential.IsActive ? "approved" : "suspended")">@(credential.IsActive ? "Active" : "Revoked")</span>
                            </div>
                            <div class="code">@Mask(credential.PublicKey)</div>
                            <div class="permission-list">
                                @foreach (var permission in credential.PermissionsCsv.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <span class="badge suspended">@permission</span>
                                }
                            </div>
                        </div>
                        <button class="button secondary" disabled="@(!credential.IsActive)" @onclick="() => RotateAsync(credential.Id)">Regenerate</button>
                    </div>
                }
            </div>
        </section>

        <section class="card">
            <h2>Integration Guide</h2>
            <p class="muted">Send the public API key with each request. Keep the secret server-side and rotate it immediately if exposed.</p>
            <pre class="code">Authorization: Bearer sk_live_...</pre>
        </section>
    </div>

    @if (showCreate)
    {
        <div class="modal-backdrop">
            <section class="modal">
                <div class="card-title"><h2>Create API Key</h2><button class="icon-button" @onclick="() => showCreate = false">Close</button></div>
                <div class="modal-body">
                    <label>Key name</label>
                    <input class="input" @bind="keyName" placeholder="Production API Key" />
                    <label>Environment</label>
                    <select class="input" @bind="environment">
                        <option value="@CredentialEnvironment.Sandbox">Sandbox</option>
                        <option value="@CredentialEnvironment.Production">Production</option>
                    </select>
                    <label>Permissions</label>
                    @foreach (var permission in AvailablePermissions)
                    {
                        <label class="checkbox">
                            <input type="checkbox" checked="@selectedPermissions.Contains(permission)" @onchange="args => TogglePermission(permission, args)" />
                            @permission
                        </label>
                    }
                </div>
                <div class="modal-actions">
                    <button class="button secondary" @onclick="() => showCreate = false">Cancel</button>
                    <button class="button primary" @onclick="IssueAsync">Create Key</button>
                </div>
            </section>
        </div>
    }
}

@code {
    private Merchant? merchant;
    private IssuedCredential? issued;
    private bool showCreate;
    private string keyName = "Sandbox API Key";
    private string? error;
    private CredentialEnvironment environment = CredentialEnvironment.Sandbox;
    private readonly string[] AvailablePermissions = ["payments", "refunds", "transactions", "customers", "webhooks"];
    private readonly HashSet<string> selectedPermissions = ["payments", "transactions"];

    protected override async Task OnInitializedAsync() =>
        merchant = await MerchantService.GetAccessibleAsync(null);

    private async Task IssueAsync()
    {
        if (merchant is null)
        {
            return;
        }

        try
        {
            issued = await CredentialService.IssueAsync(
                merchant.Id, keyName, environment, selectedPermissions.ToList());
            showCreate = false;
            error = null;
            merchant = await MerchantService.GetAccessibleAsync(null);
        }
        catch (InvalidOperationException exception)
        {
            error = exception.Message;
        }
    }

    private async Task RotateAsync(Guid credentialId)
    {
        try
        {
            issued = await CredentialService.RotateAsync(credentialId);
            error = null;
            merchant = await MerchantService.GetAccessibleAsync(null);
        }
        catch (InvalidOperationException exception)
        {
            error = exception.Message;
        }
    }

    private void TogglePermission(string permission, ChangeEventArgs args)
    {
        if (args.Value is true)
        {
            selectedPermissions.Add(permission);
        }
        else
        {
            selectedPermissions.Remove(permission);
        }
    }

    private static string Mask(string value) =>
        value.Length < 20 ? value : $"{value[..12]}...{value[^6..]}";
}
