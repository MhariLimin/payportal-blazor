@page "/merchant-timeline"
@rendermode InteractiveServer
@attribute [Authorize(Roles = PortalRoles.MerchantOrAdmin)]
@inject IActivityService ActivityService
@inject IMerchantService MerchantService

<PageTitle>Merchant Timeline - PayPortal</PageTitle>

<div class="page">
    <header class="page-header">
        <div><h1>Merchant Timeline</h1><p>Chronological profile, document, review, approval, and credential events.</p></div>
        <span class="muted">@items.Count events</span>
    </header>

    <AuthorizeView Roles="@PortalRoles.Admin">
        <section class="card filters">
            <select class="input" @bind="merchantId">
                <option value="">All merchants</option>
                @foreach (var merchant in merchants)
                {
                    <option value="@merchant.Id">@merchant.CompanyName</option>
                }
            </select>
            <button class="button primary" @onclick="LoadAsync">Apply</button>
        </section>
    </AuthorizeView>

    <section class="card">
        <div class="timeline">
            @if (items.Count == 0)
            {
                <div class="empty-state muted">No timeline events found.</div>
            }
            @foreach (var item in items.OrderBy(x => x.CreatedAtUtc))
            {
                <div class="timeline-item">
                    <span class="timeline-dot @(IsComplete(item) ? "complete" : "")"></span>
                    <div>
                        <strong>@item.Title</strong>
                        <p class="muted">@item.Description</p>
                        <small>@item.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</small>
                    </div>
                </div>
            }
        </div>
    </section>
</div>

@code {
    private IReadOnlyList<Merchant> merchants = [];
    private IReadOnlyList<ActivityLogItem> items = [];
    private string merchantId = "";

    protected override async Task OnInitializedAsync()
    {
        merchants = await MerchantService.ListAsync(null, null, null);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var filter = new ActivityLogFilter(
            Guid.TryParse(merchantId, out var parsedMerchantId) ? parsedMerchantId : null,
            null,
            null,
            null,
            null);
        items = await ActivityService.ListAsync(filter, 150);
    }

    private static bool IsComplete(ActivityLogItem item) =>
        item.Action.Contains("approved", StringComparison.OrdinalIgnoreCase)
        || item.Action.Contains("verified", StringComparison.OrdinalIgnoreCase)
        || item.Action.Contains("completed", StringComparison.OrdinalIgnoreCase);
}
