@page "/notifications"
@rendermode InteractiveServer
@attribute [Authorize(Roles = PortalRoles.Merchant)]
@inject IActivityService ActivityService

<PageTitle>Notifications - PayPortal</PageTitle>

<div class="page">
    <header class="page-header">
        <div><h1>Notifications</h1><p>Merchant-specific requests, review updates, and next actions.</p></div>
        <span class="muted">@items.Count updates</span>
    </header>

    <section class="grid two">
        <article class="card">
            <h2>Action Required</h2>
            <div class="list compact-list">
                @foreach (var item in items.Where(IsActionRequired).Take(5))
                {
                    <a class="list-row" href="@ActivityUrl(item)">
                        <span class="timeline-dot"></span>
                        <span class="list-row-main"><h3>@item.Title</h3><p>@item.Description</p></span>
                    </a>
                }
                @if (!items.Any(IsActionRequired))
                {
                    <div class="empty-state muted">No immediate action is required.</div>
                }
            </div>
        </article>

        <article class="card">
            <h2>Recent Updates</h2>
            <div class="list compact-list">
                @foreach (var item in items.Take(8))
                {
                    <a class="list-row" href="@ActivityUrl(item)">
                        <span class="timeline-dot complete"></span>
                        <span class="list-row-main">
                            <h3>@item.Title</h3>
                            <p>@item.Description</p>
                            <small class="muted">@item.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</small>
                        </span>
                    </a>
                }
            </div>
        </article>
    </section>
</div>

@code {
    private IReadOnlyList<ActivityLogItem> items = [];

    protected override async Task OnInitializedAsync() =>
        items = await ActivityService.ListAsync(new ActivityLogFilter(null, null, null, null, null), 30);

    private static bool IsActionRequired(ActivityLogItem item) =>
        item.Action is "application_moreinformationrequired" or "kyc_document_rejected";

    private static string ActivityUrl(ActivityLogItem item) =>
        item.Action.Contains("document", StringComparison.OrdinalIgnoreCase) ? "/kyc" : "/merchant/profile";
}
