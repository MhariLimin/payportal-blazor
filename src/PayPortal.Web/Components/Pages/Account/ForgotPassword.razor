@page "/account/forgot-password"
@layout AccountLayout
@attribute [AllowAnonymous]
@inject UserManager<PortalUser> UserManager

<PageTitle>Reset password - PayPortal</PageTitle>
<section class="account-card">
    <h1>Reset your password</h1>
    <p class="muted">Enter your email to create a password reset link.</p>
    @if (submitted)
    {
        <div class="alert success">If the account exists, a reset link has been created.</div>
        @if (resetUrl is not null)
        {
            <a class="button secondary full" href="@resetUrl">Open development reset link</a>
        }
    }
    else
    {
        <EditForm Model="Input" method="post" FormName="forgot" OnValidSubmit="SubmitAsync">
            <DataAnnotationsValidator />
            <label>Email address</label>
            <InputText class="input" @bind-Value="Input.Email" />
            <ValidationMessage For="() => Input.Email" />
            <button class="button primary full" type="submit">Create reset link</button>
        </EditForm>
    }
</section>

@code {
    [SupplyParameterFromForm] private ForgotModel Input { get; set; } = new();
    private bool submitted;
    private string? resetUrl;

    private async Task SubmitAsync()
    {
        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user is not null)
        {
            var token = await UserManager.GeneratePasswordResetTokenAsync(user);
            resetUrl = $"/account/reset-password?email={Uri.EscapeDataString(Input.Email)}&token={Uri.EscapeDataString(token)}";
        }
        submitted = true;
    }

    private sealed class ForgotModel
    {
        [Required, EmailAddress] public string Email { get; set; } = "";
    }
}
