@page "/account/register"
@layout AccountLayout
@attribute [AllowAnonymous]
@inject IRegistrationService RegistrationService
@inject UserManager<PortalUser> UserManager
@inject SignInManager<PortalUser> SignInManager
@inject NavigationManager Navigation

<PageTitle>Merchant registration - PayPortal</PageTitle>
<section class="account-card wide">
    <h1>Apply as a merchant</h1>
    <p class="muted">Create your account and submit the core business profile.</p>
    @if (errors.Count > 0)
    {
        <div class="alert error">@string.Join(" ", errors)</div>
    }
    <EditForm Model="Input" method="post" FormName="register" OnValidSubmit="RegisterAsync">
        <DataAnnotationsValidator />
        <div class="form-grid">
            <div><label>Company name <span class="required-dot" title="Required"></span></label><InputText class="input" @bind-Value="Input.CompanyName" /><ValidationMessage For="() => Input.CompanyName" /></div>
            <div>
                <label>Business type <span class="required-dot" title="Required"></span></label>
                <InputSelect class="input" @bind-Value="Input.BusinessType">
                    <option value="">Select a business type</option>
                    @foreach (var option in MerchantOptions.BusinessTypes)
                    {
                        <option value="@option">@option</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => Input.BusinessType" />
            </div>
            <div>
                <label>Industry <span class="required-dot" title="Required"></span></label>
                <InputSelect class="input" @bind-Value="Input.Industry">
                    <option value="">Select an industry</option>
                    @foreach (var option in MerchantOptions.Industries)
                    {
                        <option value="@option">@option</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => Input.Industry" />
            </div>
            <div><label>Tax ID <span class="required-dot" title="Required"></span></label><InputText class="input" @bind-Value="Input.TaxId" /><ValidationMessage For="() => Input.TaxId" /></div>
            <div><label>Primary contact <span class="required-dot" title="Required"></span></label><InputText class="input" @bind-Value="Input.ContactName" /><ValidationMessage For="() => Input.ContactName" /></div>
            <div><label>Email <span class="required-dot" title="Required"></span></label><InputText class="input" @bind-Value="Input.Email" /><ValidationMessage For="() => Input.Email" /></div>
            <div><label>Phone</label><InputText class="input" @bind-Value="Input.Phone" /></div>
            <div class="span-2"><label>Street address <span class="required-dot" title="Required"></span></label><InputText class="input" @bind-Value="Input.StreetAddress" /><ValidationMessage For="() => Input.StreetAddress" /></div>
            <div><label>City <span class="required-dot" title="Required"></span></label><InputText class="input" @bind-Value="Input.City" /><ValidationMessage For="() => Input.City" /></div>
            <div><label>State/Province</label><InputText class="input" @bind-Value="Input.State" /></div>
            <div><label>Postal code <span class="required-dot" title="Required"></span></label><InputText class="input" @bind-Value="Input.PostalCode" /><ValidationMessage For="() => Input.PostalCode" /></div>
            <div><label>Country <span class="required-dot" title="Required"></span></label><InputText class="input" @bind-Value="Input.Country" /><ValidationMessage For="() => Input.Country" /></div>
            <div><label>Password <span class="required-dot" title="Required"></span></label><InputText class="input" type="password" @bind-Value="Input.Password" /><ValidationMessage For="() => Input.Password" /></div>
            <div><label>Confirm password <span class="required-dot" title="Required"></span></label><InputText class="input" type="password" @bind-Value="Input.ConfirmPassword" /><ValidationMessage For="() => Input.ConfirmPassword" /></div>
        </div>
        <ValidationSummary />
        <button class="button primary full" type="submit">Create merchant account</button>
    </EditForm>
    <div class="account-links"><a href="/account/login">Already registered? Sign in</a></div>
</section>

@code {
    [SupplyParameterFromForm] private MerchantRegistrationModel Input { get; set; } = new();
    private IReadOnlyList<string> errors = [];

    private async Task RegisterAsync()
    {
        var result = await RegistrationService.RegisterMerchantAsync(Input);
        if (!result.Succeeded)
        {
            errors = result.Errors;
            return;
        }

        var user = await UserManager.FindByEmailAsync(Input.Email);
        await SignInManager.SignInAsync(user!, isPersistent: false);
        Navigation.NavigateTo("/", forceLoad: true);
    }
}
