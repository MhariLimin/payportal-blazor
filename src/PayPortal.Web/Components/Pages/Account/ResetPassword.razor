@page "/account/reset-password"
@layout AccountLayout
@attribute [AllowAnonymous]
@inject UserManager<PortalUser> UserManager
@inject NavigationManager Navigation

<PageTitle>Choose new password - PayPortal</PageTitle>
<section class="account-card">
    <h1>Choose a new password</h1>
    @if (!string.IsNullOrWhiteSpace(error)) { <div class="alert error">@error</div> }
    <EditForm Model="Input" method="post" FormName="reset" OnValidSubmit="ResetAsync">
        <DataAnnotationsValidator /><AntiforgeryToken />
        <InputText type="hidden" @bind-Value="Input.Email" />
        <InputText type="hidden" @bind-Value="Input.Token" />
        <label>New password</label><InputText class="input" type="password" @bind-Value="Input.Password" />
        <label>Confirm password</label><InputText class="input" type="password" @bind-Value="Input.ConfirmPassword" />
        <ValidationSummary />
        <button class="button primary full" type="submit">Reset password</button>
    </EditForm>
</section>

@code {
    [SupplyParameterFromForm] private ResetModel Input { get; set; } = new();
    [SupplyParameterFromQuery(Name = "email")] public string? Email { get; set; }
    [SupplyParameterFromQuery(Name = "token")] public string? Token { get; set; }
    private string? error;

    protected override void OnParametersSet()
    {
        Input.Email = string.IsNullOrWhiteSpace(Input.Email) ? Email ?? "" : Input.Email;
        Input.Token = string.IsNullOrWhiteSpace(Input.Token) ? Token ?? "" : Input.Token;
    }

    private async Task ResetAsync()
    {
        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user is null)
        {
            Navigation.NavigateTo("/account/login", true);
            return;
        }

        var result = await UserManager.ResetPasswordAsync(user, Input.Token, Input.Password);
        if (result.Succeeded)
        {
            Navigation.NavigateTo("/account/login", true);
            return;
        }
        error = string.Join(" ", result.Errors.Select(x => x.Description));
    }

    private sealed class ResetModel
    {
        public string Email { get; set; } = "";
        public string Token { get; set; } = "";
        [Required, MinLength(8)] public string Password { get; set; } = "";
        [Compare(nameof(Password))] public string ConfirmPassword { get; set; } = "";
    }
}
