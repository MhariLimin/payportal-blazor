@page "/applications"
@page "/admin/reviews"
@rendermode InteractiveServer
@attribute [Authorize(Roles = PortalRoles.Admin)]
@inject IMerchantService MerchantService
@inject IReviewService ReviewService

<PageTitle>Applications - PayPortal</PageTitle>

<div class="page">
    <header class="page-header">
        <div><h1>Applications</h1><p>Focused workspace for pending KYC decisions, evidence checks, and reviewer notes.</p></div>
        <span class="muted">@Pending.Count awaiting action</span>
    </header>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="alert @(success ? "success" : "error")">@message</div>
    }

    <section class="card flush">
        <div class="card-title">
            <div><h2>Review Queue</h2><span class="muted">Applications appear here when they are pending or under compliance review.</span></div>
            <div class="header-actions">
                <button class="button secondary" disabled="@(selectedMerchants.Count == 0)" @onclick="ExportSelected">Export selected</button>
                <button class="button secondary" disabled="@(selectedMerchants.Count == 0)" @onclick="ClearSelection">Clear selection</button>
            </div>
        </div>
        <div class="list">
            @if (Pending.Count == 0)
            {
                <div class="empty-state"><h2>No pending applications</h2><p class="muted">All applications have been processed.</p></div>
            }
            @foreach (var merchant in Pending)
            {
                <div class="application-row">
                    <input type="checkbox" checked="@selectedMerchants.Contains(merchant.Id)" @onchange="args => ToggleMerchant(merchant.Id, args)" />
                    @if (!string.IsNullOrWhiteSpace(merchant.LogoStorageName))
                    {
                        <img class="company-logo" src="/merchant-logos/@merchant.Id" alt="" />
                    }
                    else
                    {
                        <span class="company-icon">PP</span>
                    }
                    <span class="list-row-main">
                        <h3>@merchant.CompanyName</h3>
                        <p>@(merchant.Industry ?? "Industry not provided") | @merchant.BusinessType | @DocumentReadiness(merchant)</p>
                    </span>
                    <StatusBadge Value="merchant.RiskLevel" />
                    <StatusBadge Value="merchant.Status" />
                    <a class="button secondary" href="/merchants/@merchant.Id">View profile</a>
                    <button class="button primary" @onclick="() => Select(merchant)">Review</button>
                </div>
            }
        </div>
    </section>
</div>

@if (selected is not null)
{
    <div class="modal-backdrop">
        <section class="modal review-modal">
            <div class="card-title">
                <div><h2>Review Application</h2><span class="muted">@selected.CompanyName</span></div>
                <button class="icon-button" @onclick="Close">Close</button>
            </div>
            <div class="modal-body review-body">
                <section class="grid three">
                    <div class="review-stat"><span>Risk</span><strong>@selected.RiskLevel</strong></div>
                    <div class="review-stat"><span>Status</span><strong>@FormatStatus(selected.Status)</strong></div>
                    <div class="review-stat"><span>Applied</span><strong>@selected.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy")</strong></div>
                </section>

                <h3>Primary Contact</h3>
                @if (selected.Contacts.FirstOrDefault() is { } contact)
                {
                    <div class="address-block"><strong>@contact.Name</strong><span>@(contact.Position ?? "Contact")</span><span>@contact.Email | @(contact.Phone ?? "No phone")</span></div>
                }

                <h3>Evidence Checklist</h3>
                <div class="list bordered">
                    @foreach (var requirement in Requirements)
                    {
                        var document = selected.KycDocuments
                            .Where(x => x.DocumentType == requirement.Type)
                            .OrderByDescending(x => x.CreatedAtUtc)
                            .FirstOrDefault();
                        <div class="list-row">
                            <span class="requirement-state">@(document is null ? "!" : document.Status == DocumentStatus.Verified ? "OK" : "...")</span>
                            <span class="list-row-main">
                                <h3>@requirement.Label</h3>
                                <p>@(document is null ? "Missing upload" : $"{document.DocumentName} | {FormatBytes(document.FileSize)}")</p>
                            </span>
                            @if (document is not null)
                            {
                                <StatusBadge Value="document.Status" />
                                <span class="badge approved">Scan Passed</span>
                                <a class="button secondary" href="/kyc-documents/@document.Id/download">View or download</a>
                                <button class="button secondary" disabled="@submitting" @onclick="() => ReviewDocumentAsync(document.Id, DocumentStatus.Verified)">Verify</button>
                                <button class="button danger" disabled="@submitting" @onclick="() => ReviewDocumentAsync(document.Id, DocumentStatus.Rejected)">Reject</button>
                            }
                        </div>
                    }
                </div>

                @if (selected.Reviews.Any(x => x.ReviewType == "admin_note"))
                {
                    <h3>Internal Admin Notes</h3>
                    @foreach (var note in selected.Reviews.Where(x => x.ReviewType == "admin_note").OrderByDescending(x => x.CreatedAtUtc))
                    {
                        <div class="review-history">
                            <strong>Internal Note</strong>
                            <span>@note.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</span>
                            <p>@note.Notes</p>
                        </div>
                    }
                }

                @if (selected.Reviews.Any(x => x.ReviewType != "admin_note"))
                {
                    <h3>Review History</h3>
                    @foreach (var review in selected.Reviews.Where(x => x.ReviewType != "admin_note").OrderByDescending(x => x.CreatedAtUtc))
                    {
                        <div class="review-history">
                            <strong>@FormatDecision(review.Decision)</strong>
                            <span>@review.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</span>
                            <p>@review.Notes</p>
                        </div>
                    }
                }

                <h3>Decision</h3>
                <div class="alert">
                    Complete Compliance Review after required documents are present and evidence has been checked. Approval is a separate final decision.
                </div>
                <div class="decision-grid">
                    <button class="decision approved @(decision == ReviewDecision.Approved ? "selected" : "")" @onclick="() => decision = ReviewDecision.Approved">Approve</button>
                    <button class="decision rejected @(decision == ReviewDecision.Rejected ? "selected" : "")" @onclick="() => decision = ReviewDecision.Rejected">Reject</button>
                    <button class="decision pending @(decision == ReviewDecision.MoreInformationRequired ? "selected" : "")" @onclick="() => decision = ReviewDecision.MoreInformationRequired">Request Documents</button>
                </div>
                <label>Reviewer notes</label>
                <textarea class="input" rows="4" @bind="notes" placeholder="Explain the decision or documents required..."></textarea>
                <button class="button secondary" disabled="@submitting" @onclick="SaveAdminNoteAsync">Save as Internal Admin Note</button>
            </div>
            <div class="modal-actions">
                <button class="button secondary" @onclick="Close">Cancel</button>
                <button class="button secondary" disabled="@submitting" @onclick="CompleteComplianceAsync">Complete Compliance Review</button>
                <button class="button primary" disabled="@submitting" @onclick="SubmitAsync">@(submitting ? "Submitting..." : "Submit Decision")</button>
            </div>
        </section>
    </div>
}

@code {
    [SupplyParameterFromQuery] public Guid? MerchantId { get; set; }
    private IReadOnlyList<Merchant> merchants = [];
    private Merchant? selected;
    private ReviewDecision decision = ReviewDecision.MoreInformationRequired;
    private string notes = "";
    private string? message;
    private bool success;
    private bool submitting;
    private readonly HashSet<Guid> selectedMerchants = [];
    private readonly (string Type, string Label)[] Requirements =
    [
        ("business_registration", "Certificate of Incorporation"),
        ("tax_certificate", "Tax Registration Certificate"),
        ("id_document", "Director ID Document")
    ];
    private IReadOnlyList<Merchant> Pending => merchants
        .Where(x => x.Status is MerchantStatus.Pending or MerchantStatus.UnderReview)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        if (MerchantId.HasValue)
        {
            selected = merchants.SingleOrDefault(x => x.Id == MerchantId);
        }
    }

    private void Select(Merchant merchant)
    {
        selected = merchant;
        decision = ReviewDecision.MoreInformationRequired;
        notes = "";
    }

    private void Close() => selected = null;

    private void ToggleMerchant(Guid merchantId, ChangeEventArgs args)
    {
        if (args.Value is true)
        {
            selectedMerchants.Add(merchantId);
        }
        else
        {
            selectedMerchants.Remove(merchantId);
        }
    }

    private void ClearSelection()
    {
        selectedMerchants.Clear();
        message = null;
    }

    private void ExportSelected()
    {
        var selectedNames = merchants
            .Where(x => selectedMerchants.Contains(x.Id))
            .Select(x => x.CompanyName)
            .ToList();
        success = true;
        message = $"Prepared export for {selectedNames.Count} selected applications: {string.Join(", ", selectedNames)}.";
    }

    private async Task SubmitAsync()
    {
        if (selected is null || string.IsNullOrWhiteSpace(notes))
        {
            success = false;
            message = "Reviewer notes are required.";
            return;
        }

        submitting = true;
        try
        {
            await ReviewService.ReviewAsync(selected.Id, new ReviewRequest(decision, notes));
            success = true;
            message = $"Decision recorded for {selected.CompanyName}.";
            selected = null;
            await RefreshAsync();
        }
        catch (Exception exception) when (exception is InvalidOperationException or UnauthorizedAccessException)
        {
            success = false;
            message = exception.Message;
        }
        finally
        {
            submitting = false;
        }
    }

    private async Task CompleteComplianceAsync()
    {
        if (selected is null || string.IsNullOrWhiteSpace(notes))
        {
            success = false;
            message = "Reviewer notes are required to complete compliance review.";
            return;
        }

        submitting = true;
        try
        {
            await ReviewService.CompleteComplianceReviewAsync(selected.Id, notes);
            success = true;
            message = $"Compliance review completed for {selected.CompanyName}.";
            await RefreshAsync();
            selected = merchants.SingleOrDefault(x => x.Id == selected.Id);
        }
        catch (Exception exception) when (exception is InvalidOperationException or UnauthorizedAccessException)
        {
            success = false;
            message = exception.Message;
        }
        finally
        {
            submitting = false;
        }
    }

    private async Task SaveAdminNoteAsync()
    {
        if (selected is null || string.IsNullOrWhiteSpace(notes))
        {
            success = false;
            message = "Admin note text is required.";
            return;
        }

        submitting = true;
        try
        {
            await ReviewService.AddAdminNoteAsync(selected.Id, notes);
            success = true;
            message = "Internal admin note saved.";
            var selectedId = selected.Id;
            notes = "";
            await RefreshAsync();
            selected = merchants.SingleOrDefault(x => x.Id == selectedId);
        }
        catch (Exception exception) when (exception is InvalidOperationException or UnauthorizedAccessException)
        {
            success = false;
            message = exception.Message;
        }
        finally
        {
            submitting = false;
        }
    }

    private async Task ReviewDocumentAsync(Guid documentId, DocumentStatus status)
    {
        if (selected is null)
        {
            return;
        }

        if (status == DocumentStatus.Rejected && string.IsNullOrWhiteSpace(notes))
        {
            success = false;
            message = "Reviewer notes are required when rejecting a document.";
            return;
        }

        submitting = true;
        try
        {
            var reviewNotes = status == DocumentStatus.Verified
                ? string.IsNullOrWhiteSpace(notes) ? "Document verified." : notes
                : notes;
            await ReviewService.ReviewDocumentAsync(documentId, new DocumentReviewRequest(status, reviewNotes));
            success = true;
            message = status == DocumentStatus.Verified ? "Document verified." : "Document rejected.";
            var selectedId = selected.Id;
            await RefreshAsync();
            selected = merchants.SingleOrDefault(x => x.Id == selectedId);
        }
        catch (Exception exception) when (exception is InvalidOperationException or UnauthorizedAccessException)
        {
            success = false;
            message = exception.Message;
        }
        finally
        {
            submitting = false;
        }
    }

    private async Task RefreshAsync() =>
        merchants = await MerchantService.ListAsync(null, null, null);

    private static string FormatStatus(MerchantStatus status) =>
        status == MerchantStatus.UnderReview ? "Under Review" : status.ToString();

    private static string FormatDecision(ReviewDecision decision) =>
        decision switch
        {
            ReviewDecision.MoreInformationRequired => "More Information Required",
            ReviewDecision.ComplianceReviewed => "Compliance Reviewed",
            _ => decision.ToString()
        };

    private string DocumentReadiness(Merchant merchant)
    {
        var uploaded = Requirements.Count(x => merchant.KycDocuments.Any(document => document.DocumentType == x.Type));
        return $"{uploaded}/{Requirements.Length} required documents";
    }

    private static string FormatBytes(long bytes) =>
        bytes >= 1024 * 1024 ? $"{bytes / 1024d / 1024d:F1} MB" : $"{bytes / 1024d:F1} KB";
}
